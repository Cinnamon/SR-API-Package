        "/api/v3.4/users/search/": {
            "get": {
                "tags": [
                    "User Management"
                ],
                "summary": "Search Users",
                "description": "Search users by keyword with optional group filter and optional system-wide scope.\n\nEach result item includes the `lock_until` field.\n\n### Search Modes\n\n| Mode | Who | Behaviour |\n|------|-----|----------|\n| Default (`all=false`, no `group_id`) | SA (`user:readall`) or GA with `allow_group_admin_access_unassigned` | Search across all accessible users |\n| Default (`all=false`, `group_id` set) | Any user with `user:read` | Search within the specified group |\n| `all=true` | System Admin only | Search all users system-wide regardless of group |\n\n### Notes\n\n- `keyword` is required; an empty string is valid.\n- `sort` is required (no default).\n- `size` defaults to 10 when omitted.",
                "operationId": "search_users_api_v3_4_users_search__get",
                "security": [
                    {
                        "MyHTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "keyword",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Search term matched against username, first name, last name, and display name. Empty string is allowed.",
                        "example": "general"
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "id",
                                "username",
                                "first_name",
                                "last_name",
                                "display_name",
                                "last_login",
                                "created_at",
                                "updated_at",
                                "-id",
                                "-username",
                                "-first_name",
                                "-last_name",
                                "-display_name",
                                "-last_login",
                                "-created_at",
                                "-updated_at"
                            ]
                        },
                        "description": "Field to sort results by. Prefix with `-` for descending order."
                    },
                    {
                        "name": "skip",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 0,
                            "default": 0
                        },
                        "description": "Number of records to skip for pagination"
                    },
                    {
                        "name": "size",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "enum": [
                                10,
                                20,
                                50
                            ],
                            "default": 10
                        },
                        "description": "Page size"
                    },
                    {
                        "name": "group_id",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "pattern": "^[0-9a-f]{32}$"
                        },
                        "description": "Filter search to a specific group (32-character hex UUID)"
                    },
                    {
                        "name": "all",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "default": false
                        },
                        "description": "If `true`, search all users system-wide. **System Admin only.** Non-SA callers receive 403."
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserList"
                                },
                                "example": {
                                    "total": 2,
                                    "items": [
                                        {
                                            "id": "548e51052c3e4159b25a21b2566c474d",
                                            "username": "generaluser3@example.com",
                                            "first_name": "General",
                                            "last_name": "User 3",
