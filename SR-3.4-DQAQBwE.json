        "/api/v3.4/users/{user_id}/": {
            "get": {
                "tags": [
                    "User Management"
                ],
                "summary": "Get User by ID",
                "description": "Retrieve detailed information for a single user, including group memberships and lockout state.\n\n### lock_until Interpretation\n\n- `null` — user can log in normally\n- Future datetime — user is locked; auto-unlock occurs at this time (if policy allows)\n- `9999-12-31T00:00:00Z` — user is locked indefinitely (`manual_only` policy); requires admin unlock",
                "operationId": "read_user_by_id_api_v3_4_users__user_id__get",
                "security": [
                    {
                        "MyHTTPBearer": []
                    }
                ],
                "parameters": [
                    {
                        "name": "user_id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "pattern": "^[0-9a-f]{32}$"
                        },
                        "description": "User ID in 32-character hex format (no dashes)",
                        "example": "a56bff68b1294b9c9d23bd64764d2a99"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
